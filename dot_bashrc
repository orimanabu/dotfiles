# .bashrc

# Source global definitions
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

# User specific environment
if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]; then
    PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi
export PATH

# Uncomment the following line if you don't like systemctl's auto-paging feature:
# export SYSTEMD_PAGER=

# User specific aliases and functions
if [ -d ~/.bashrc.d ]; then
    for rc in ~/.bashrc.d/*; do
        if [ -f "$rc" ]; then
            . "$rc"
        fi
    done
fi
unset rc

###
### local settings
###

if ! [[ "$PATH" =~ "$HOME/devel/bin" ]]; then
    PATH="$PATH:$HOME/devel/bin"
fi
export PATH
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

export PATH
shopt -s histappend
export HISTCONTROL=ignoredups:erasedups
export HISTSIZE=99999
PROMPT_COMMAND="history -a; history -c; history -r; $PROMPT_COMMAND"

export EDITOR=vim
export GOPATH=${HOME}/devel

eval "$(mise activate bash)"
alias g='pushd $(ghq root)/$(ghq list | peco)'
alias otpcopy="otp.py | xclip -selection c"
alias otpecho="otp.py ; echo"
alias open=xdg-open
alias vpnup="sudo nmcli c up '1 - Red Hat Global VPN' --ask"

export CLAUDE_CODE_USE_VERTEX=1
export CLOUD_ML_REGION=global
#export ANTHROPIC_VERTEX_PROJECT_ID=itpc-gcp-global-revenue-claude
export ANTHROPIC_VERTEX_PROJECT_ID=itpc-gcp-xe-eng-claude
